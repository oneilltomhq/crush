# Required: voice service API keys
DEEPGRAM_API_KEY=your-deepgram-api-key
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Required for direct Anthropic access (not needed on exe.dev which has a gateway)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: override LLM endpoint (default: https://api.anthropic.com/v1/messages)
# LLM_ENDPOINT=https://api.anthropic.com/v1/messages

# Optional: CDP host/port for browser automation (default: localhost:9222)
# CDP_HOST=localhost
# CDP_PORT=9222
