{
  "manifest_version": 3,
  "name": "Crush",
  "version": "0.1.0",
  "description": "Agentic chromium shell with 3D terminal",
  "permissions": [
    "sidePanel",
    "activeTab"
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Crush"
  }
}
